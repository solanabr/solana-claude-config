# Solana Claude Config — MCP Server Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and will never be committed.
# MCP servers in .mcp.json reference these via ${VAR} syntax.

# ── Helius (RPC, DAS API, webhooks) ──────────────────
# Get your key at: https://dev.helius.xyz
HELIUS_API_KEY=
# Optional: "devnet" or "mainnet-beta" (default)
# HELIUS_NETWORK=devnet

# ── Solana Agent Kit (on-chain actions) ──────────────
# RPC endpoint (can reuse Helius: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY)
RPC_URL=
# Base58 private key — USE A DEDICATED DEV WALLET, NEVER YOUR MAIN WALLET
SOLANA_PRIVATE_KEY=

# ── Colosseum Copilot (startup research) ─────────────
# COLOSSEUM_COPILOT_PAT=

# ── QEDGen (formal verification) ─────────────────────
# MISTRAL_API_KEY=
